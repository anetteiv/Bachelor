def ensure_output_dir(path: str):
    p = Path(path)
    p.mkdir(parents=True, exist_ok=True)
    return p


def save_or_show(fig, outpath: Path, show: bool):
    fig.tight_layout()
    fig.savefig(outpath, dpi=200)
    if show:
        plt.show()
    plt.close(fig)


