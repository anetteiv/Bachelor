def list12_to_month_series(vals12, year=2025, name="x"):
    idx = pd.date_range(f"{year}-01-01", f"{year}-12-01", freq="MS")
    return pd.Series(vals12, index=idx, name=name).astype(float)


def monthly_kwh_from_kw_hourly(P_kw_hourly: pd.Series) -> pd.Series:
    return P_kw_hourly.fillna(0.0).resample("MS").sum()


def monthly_under_cap_kwh(P_kw_hourly: pd.Series, cap_kw: float) -> pd.Series:
    P = P_kw_hourly.fillna(0.0).values
    under = np.minimum(P, cap_kw)
    return pd.Series(under, index=P_kw_hourly.index).resample("MS").sum()


def monthly_savings_kr_for_location(P_kw_hourly: pd.Series,
                                    kg_12, price_12, tax_12,
                                    cases_kw, year=2025) -> pd.DataFrame:
    kg_m = list12_to_month_series(kg_12, year, "kg_invoice")
    price_m = list12_to_month_series(price_12, year, "price_krkg")
    tax_m = list12_to_month_series(tax_12, year, "tax_krkg")
    unit_m = price_m + tax_m

    E_tot_m = monthly_kwh_from_kw_hourly(P_kw_hourly)

    out = pd.DataFrame(index=E_tot_m.index)
    out["E_tot_kWh"] = E_tot_m
    out["kg_invoice"] = kg_m
    out["kr_per_kg_total"] = unit_m

    for cap in cases_kw:
        E_under_m = monthly_under_cap_kwh(P_kw_hourly, cap)
        frac = (E_under_m / E_tot_m.replace(0, np.nan)).fillna(0.0)

        kg_saved = kg_m * frac
        kr_saved = kg_saved * unit_m

        mw = cap / 1000
        out[f"E_flis_{mw:.1f}MW_kWh"] = E_under_m
        out[f"kg_spart_{mw:.1f}MW"] = kg_saved
        out[f"kr_spart_{mw:.1f}MW"] = kr_saved

    out.index = out.index.strftime("%b")
    return out


