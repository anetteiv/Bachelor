def thousands(x, pos):
    return f"{int(round(x)):,}".replace(",", ".")


def load_gass_tft(file: Path, sheet=0, start_row=2, date_col=0, power_col=1):
    df = pd.read_excel(file, sheet_name=sheet, skiprows=start_row - 1, header=None)
    ts = pd.to_datetime(df.iloc[:, date_col], errors="coerce")
    kw = pd.to_numeric(df.iloc[:, power_col], errors="coerce")
    out = pd.DataFrame({"kW": kw.values}, index=ts)
    out = out[~out.index.isna()].sort_index()
    out = out.dropna(subset=["kW"])
    return out


def force_full_year_hourly(power_kw: pd.Series, year=2025) -> pd.Series:
    full_year = pd.date_range(f"{year}-01-01 00:00", f"{year}-12-31 23:00", freq="H")
    s = power_kw.resample("H").mean().reindex(full_year)
    return s.fillna(0.0)


def monthly_area_under_cap(power_kw_hourly: pd.Series, cap_kw: float) -> pd.DataFrame:
    P = power_kw_hourly.fillna(0.0)
    under = np.minimum(P.values, cap_kw)
    over = np.maximum(P.values - cap_kw, 0.0)

    df = pd.DataFrame({
        "P_kW": P.values,
        "P_under_kW": under,
        "P_over_kW": over,
    }, index=P.index)

    monthly = df.resample("MS")[["P_under_kW", "P_over_kW"]].sum().rename(columns={
        "P_under_kW": "E_under_kWh",
        "P_over_kW": "E_over_kWh"
    })

    monthly["E_total_kWh"] = monthly["E_under_kWh"] + monthly["E_over_kWh"]
    monthly["cap_kW"] = cap_kw
    return monthly


