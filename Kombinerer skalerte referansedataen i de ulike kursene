def les_skalert_fil(byggnavn, mappe_skalert):
    filnavn = f"{byggnavn}_skalert.xlsx"
    filsti = os.path.join(mappe_skalert, filnavn)

    if not os.path.exists(filsti):
        print(f"Fant ikke fil: {filnavn}")
        return None, filsti

    df = pd.read_excel(filsti)
    df.columns = df.columns.astype(str).str.strip()

    if "Dato" not in df.columns:
        raise ValueError(f"Filen {filnavn} mangler kolonnen 'Dato'.")

    df["Dato"] = pd.to_datetime(df["Dato"], errors="coerce")
    df = df.dropna(subset=["Dato"]).copy()

    mulige_kolonner = [
        "Energy_total_scaled",
        "Energy_scaled",
        "Energy_total",
        "Energy"
    ]

    energikolonne = None
    for kol in mulige_kolonner:
        if kol in df.columns:
            energikolonne = kol
            break

    if energikolonne is None:
        raise ValueError(
            f"Filen {filnavn} mangler en forventet energikolonne. "
            f"Fant ikke noen av: {mulige_kolonner}"
        )

    df[energikolonne] = pd.to_numeric(df[energikolonne], errors="coerce")
    df = df.dropna(subset=[energikolonne]).copy()

    df = df.groupby("Dato", as_index=False)[energikolonne].sum()

    df = df.rename(columns={energikolonne: byggnavn})

    return df, filsti

